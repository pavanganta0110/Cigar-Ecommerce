{
  "name": "compadres/cigar-ecommerce",
  "description": "Compadres Cigars WordPress and WooCommerce application",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "php-stubs/woocommerce-stubs": "^10.0",
    "php-stubs/wordpress-stubs": "^6.9",
    "phpunit/phpunit": "^9.6",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.2",
    "yoast/phpunit-polyfills": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "Compadres\\Commerce\\": "wp-content/plugins/compadres-commerce/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Compadres\\Commerce\\Tests\\": "wp-content/plugins/compadres-commerce/tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "analyse": "phpstan analyse --memory-limit=1G",
    "test:unit": "phpunit --testsuite unit",
    "test": ["@lint", "@analyse", "@test:unit"]
  }
}
