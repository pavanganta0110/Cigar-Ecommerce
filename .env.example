# Local development only. Replace every value in staging/production.
COMPOSE_PROJECT_NAME=compadres_cigars
APP_ENV=local
WP_PORT=8080
WP_URL=http://localhost:8080
WP_TITLE="Compadres Cigars Development"
WP_ADMIN_USER=compadres_admin
WP_ADMIN_PASSWORD=replace-with-a-local-password
WP_ADMIN_EMAIL=developer@example.test

DB_NAME=compadres
DB_USER=compadres
DB_PASSWORD=replace-with-a-local-db-password
DB_ROOT_PASSWORD=replace-with-a-local-root-password
DB_HOST=db:3306

WORDPRESS_DEBUG=true
WORDPRESS_CONFIG_EXTRA=
WOOCOMMERCE_VERSION=10.9.4

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# External integrations are disabled until configured and approved.
COMPADRES_AGE_PROVIDER=mock
COMPADRES_AGE_REQUIRED=true
COMPADRES_AGECHECKER_API_URL=
COMPADRES_AGECHECKER_API_KEY=
COMPADRES_TAX_PROVIDER=mock
COMPADRES_AVALARA_API_URL=
COMPADRES_AVALARA_ACCOUNT_ID=
COMPADRES_AVALARA_LICENSE_KEY=
COMPADRES_AVALARA_COMPANY_CODE=
COMPADRES_PAYMENT_PROVIDER=mock
COMPADRES_PAYMENT_PRODUCTION_APPROVED=false
COMPADRES_AUTHORIZE_NET_LOGIN_ID=
COMPADRES_AUTHORIZE_NET_TRANSACTION_KEY=
COMPADRES_AUTHORIZE_NET_SIGNATURE_KEY=
COMPADRES_SHIPPING_PROVIDER=mock
COMPADRES_SHIPPING_PRODUCTION_APPROVED=false
COMPADRES_UPS_CLIENT_ID=
COMPADRES_UPS_CLIENT_SECRET=
COMPADRES_UPS_ACCOUNT_NUMBER=
COMPADRES_SMTP_HOST=mailpit
COMPADRES_SMTP_PORT=1025
COMPADRES_SMTP_USERNAME=
COMPADRES_SMTP_PASSWORD=
COMPADRES_GA4_MEASUREMENT_ID=
COMPADRES_SEARCH_CONSOLE_VERIFICATION=
