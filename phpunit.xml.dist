<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php" colors="true" failOnWarning="true" failOnRisky="true">
  <testsuites>
    <testsuite name="unit">
      <directory suffix="Test.php">wp-content/plugins/compadres-commerce/tests/Unit</directory>
    </testsuite>
  </testsuites>
  <coverage processUncoveredFiles="true">
    <include>
      <directory suffix=".php">wp-content/plugins/compadres-commerce/src</directory>
    </include>
  </coverage>
</phpunit>
